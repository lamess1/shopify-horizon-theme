    "two_images": {
      "type": "custom-liquid",
      "name": "Zwei Bilder",
      "settings": {
        "custom_liquid": "<style>.kg-two-img{display:grid;grid-template-columns:1fr 1fr;gap:4px;background:#FDF8F3;padding-bottom:4px;}@media(max-width:640px){.kg-two-img{grid-template-columns:1fr;}}.kg-img-slot{min-height:340px;background:#F3DED3;display:flex;align-items:center;justify-content:center;}.kg-img-slot__ph{text-align:center;color:#994B30;opacity:.5;font-size:.8125rem;padding:1rem;}</style><div class=\"kg-two-img\"><div class=\"kg-img-slot\"><div class=\"kg-img-slot__ph\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\"/><circle cx=\"8.5\" cy=\"8.5\" r=\"1.5\"/><polyline points=\"21 15 16 10 5 21\"/></svg><p>Bild 1 folgt</p></div></div><div class=\"kg-img-slot\"><div class=\"kg-img-slot__ph\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\"/><circle cx=\"8.5\" cy=\"8.5\" r=\"1.5\"/><polyline points=\"21 15 16 10 5 21\"/></svg><p>Bild 2 folgt</p></div></div></div>",
